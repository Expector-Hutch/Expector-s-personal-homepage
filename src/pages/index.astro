---
import "@/styles/globals.css";

import icon from "@/assets/icon.svg?raw";

import Hitokoto from "@/components/Hitokoto.astro";
import GithubLink from "@/components/GithubLink.astro";
import LightButton from "@/components/LightButton.astro";
import IconLinks from "@/components/IconLinks.astro";
import MusicPlayer from "@/components/MusicPlayer.astro";
import FriendLinks from "@/components/FriendLinks.astro";
import FriendLink from "@/components/FriendLink.astro";
import Footer from "@/components/Footer.astro";

import data from "@/data/data.yaml";
---

<html lang="zh-cn" style={{ "--theme-color": "#66ccff" }}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0"
    />
    <title>{data.name} 的主页</title>
    <link rel="icon" href=`data:image/svg+xml,${encodeURIComponent(icon)}` />
  </head>

  <body>
    <div class="main-card card">
      <aside id="head-image"></aside>
      <div>
        <GithubLink href="https://github.com/Expector-Hutch/Expector-s-personal-homepage" />
        <main>
          <h1 id="title" style={{ "font-family": "Lucida Handwriting" }}>{data.name}</h1>

          <p id="self-introduction" style={{ margin: 0 }} set:html={data.introduction} />

          <Hitokoto />

          <FriendLinks>
            {
              data.friends.map(f => (
                <FriendLink name={f.name} href={f.link} icon={f.icon}>
                  {f.brief}
                </FriendLink>
              ))
            }
          </FriendLinks>

          <div class="app-links">
            <LightButton color="#ff1f71" href={data.links.bilibili}>哔站</LightButton>
            <LightButton color="#2bd2ff" href={data.links.blog}>博客</LightButton>
            <LightButton color="#11ff45" href={data.links.email}>邮箱</LightButton>
          </div>

          <MusicPlayer uid={data.music} color="#66ccff" />

          <div class="more-links">
            <IconLinks href={data.links.github} icon="github" />
            <IconLinks href={data.links.gitee} icon="gitee" />
            <IconLinks href={data.links.zhihu} icon="zhihu" />
          </div>

          <Footer />
        </main>
      </div>
    </div>
    <style>
      html,
      body {
        user-select: none;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      @media (width < 960px) {
        html,
        body {
          flex-direction: column;
          justify-content: flex-start;
        }
      }
      .main-card {
        display: flex;
        justify-content: center;
        align-items: stretch;
        flex-direction: row;
        overflow: hidden;
      }
      @media (width < 960px) {
        .main-card {
          flex-direction: column;
          justify-content: flex-start;
          overflow: auto;
        }
      }
      aside {
        background-color: var(--theme-color);
        background-image: url("@/assets/images/head-image.jpeg");
        background-position: 50%;
        background-repeat: no-repeat;
        background-size: cover;
        width: 320px;
      }
      @media (width < 960px) {
        aside {
          width: 100%;
          height: 0;
          padding-top: 100%;
          position: relative;
        }
      }
      main {
        flex-direction: column;
        width: 580px;
        padding: 33px 30px 0;
        display: flex;
      }
      @media (width < 960px) {
        main {
          width: auto;
          padding: 10px;
        }
      }
      h1 {
        text-shadow:
          0 0 7px #6cf,
          0 0 10px #6cf,
          0 0 21px #6cf,
          0 0 42px #0fa,
          0 0 82px #0fa,
          0 0 92px #0fa,
          0 0 102px #0fa,
          0 0 151px #0fa;
        font-family: "Lucida Handwriting";
      }
      .app-links {
        justify-content: space-around;
        gap: 33px;
        height: 50px;
        margin-left: 11px;
        margin-right: 11px;
        display: flex;
      }
      @media (width < 960px) {
        .app-links {
          flex-direction: column;
          height: auto;
          gap: 0;
        }
      }
      .more-links {
        gap: 0.5em;
        height: 1.5em;
        margin-left: 0.5em;
        margin-right: 0.5em;
        display: inline-flex;
      }
    </style>
  </body>
</html>

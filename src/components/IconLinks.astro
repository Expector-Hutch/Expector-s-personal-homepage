---
import GithubIcon from "~icons/simple-icons/github?height=1em&width=1em";
import GiteeIcon from "~icons/simple-icons/gitee?color=%23c71d23&height=1em&width=1em";
import ZhihuIcon from "~icons/simple-icons/zhihu?color=%230084ff&height=1em&width=1em";

const icon_map = {
  github: GithubIcon,
  gitee: GiteeIcon,
  zhihu: ZhihuIcon,
} as const;

interface Props {
  href: string;
  icon: keyof typeof icon_map;
}

const { href, icon } = Astro.props as Props;
---

<a class="icon-link" href={href} set:html={icon_map[icon]} />
<style>
  .icon-link {
    display: flex;
    align-items: center;
    color: #fff;
  }
  @media (prefers-color-scheme: light) {
    .icon-link {
      color: #000;
    }
  }
</style>
